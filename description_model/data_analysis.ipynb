   "source": [
    "Sequence count and correct sequence length analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 28,
   "id": "3caf2ecd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total number of sequences (listings): 155\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x400 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
