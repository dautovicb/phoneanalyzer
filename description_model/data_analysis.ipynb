   "metadata": {},
   "source": [
    "Sequence length analysis:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "38369683",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Average sequence length: 3136.0\n"
     ]
    }
   ],
   "source": [
    "sentences, current = [], []\n",
    "\n",
    "for line in lines:\n",
    "    if len(line.split()) == 2:  # token + label\n",
    "        current.append(line.split()[0])\n",
    "    else:  \n",
    "        if current:  \n",
    "            sentences.append(len(current))\n",
    "            current = []\n",
    "\n",
    "if current:\n",
    "    sentences.append(len(current))\n",
    "\n",
    "plt.hist(sentences, bins=30, color='orange')\n",
    "plt.title(\"Token length distribution\")\n",
    "plt.xlabel(\"Tokens per sentence\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "plt.show()\n",
    "\n",
    "if sentences:  \n",
    "    print(\"Average sequence length:\", sum(sentences)/len(sentences))\n",
    "else:\n",
    "    print(\"No sentences found in dataset\")\n"
   ]
  },
  {
