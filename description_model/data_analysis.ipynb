   "source": [
    "from collections import Counter\n",
    "\n",
    "with open('dataset/train.txt', encoding='utf-8') as f:\n",
    "    lines = [line.strip() for line in f if line.strip()]\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cec55292",
   "metadata": {},
   "source": [
    "Tag distribution:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "c5e565c5",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x500 with 1 Axes>"
      ]
     },
