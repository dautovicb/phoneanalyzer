    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total number of unique tags: 18\n",
      "Most frequent tag: [('O', 1483)]\n"
     ]
    }
   ],
   "source": [
    "tags = [line.split()[-1] for line in lines if len(line.split()) == 2]\n",
    "counts = Counter(tags)\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "plt.bar(counts.keys(), counts.values(), color='teal')\n",
    "plt.title(\"Tag distribution - Bertic dataset\")\n",
    "plt.xticks(rotation=45)\n",
    "plt.ylabel(\"Count\")\n",
    "plt.show()\n",
    "\n",
    "print(\"Total number of unique tags:\", len(counts))\n",
    "print(\"Most frequent tag:\", counts.most_common(1))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cdd93944",
   "metadata": {},
   "source": [
    "Entity tag distribution (without O tag)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "7cc71644",
   "metadata": {},
   "outputs": [
